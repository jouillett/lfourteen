{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/mypage/layout,_N_T_/mypage/shipping/layout,_N_T_/mypage/shipping/page,_N_T_/mypage/shipping"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/mypage/shipping/__PAGE__",
    "/mypage/shipping",
    "/mypage",
    "/_index",
    "/_head"
  ]
}